# =============================================================================
# AgroNavis — .gitignore
# =============================================================================

# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Build outputs ────────────────────────────────────────────────────────────
.next/
out/
build/
dist/
*.tsbuildinfo

# ─── Environment files — NEVER commit secrets ─────────────────────────────────
# Root .env is the single source of truth (local dev)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Cache ────────────────────────────────────────────────────────────────────
.cache/
.parcel-cache/
.eslintcache
.turbo

# ─── Python (ML service — future) ────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv/

# ─── ML model files ───────────────────────────────────────────────────────────
# Large binary weights — download separately; never commit
*.pt
*.pth
*.onnx
*.h5
*.pkl

# ─── OS metadata ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ─── IDE ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── Database ─────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ─── Test coverage ────────────────────────────────────────────────────────────
coverage/
*.lcov
.nyc_output

# ─── Supabase local state ─────────────────────────────────────────────────────
backend/supabase/.branches
backend/supabase/.temp

# ─── Deployment ───────────────────────────────────────────────────────────────
.vercel

# ─── Misc ─────────────────────────────────────────────────────────────────────
debug-*.html

# ─── PWA (generated by next-pwa at build time — do not commit) ────────────────
frontend/public/sw.js
frontend/public/sw.js.map
frontend/public/workbox-*.js
frontend/public/workbox-*.js.map
frontend/public/fallback-*.js
frontend/public/swe-worker-*.js
# macOS resource forks
._*
.DS_Store

# ─── WASM Auto-generated ────────────────────────────────────────────────────────
frontend/public/wasm/*.wasm
